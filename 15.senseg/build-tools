#!/bin/bash
set -e

# Build all tools to generated/

cd "$(dirname "$0")/go"

echo "Building tools to generated/..."

# Manuscript tools (Go)
go build -o ../generated/00-sanitize-manuscript ../tools/manuscript/00-sanitize-manuscript/main.go

# Manuscript tools (Bash)
cp ../tools/manuscript/04-context ../generated/04-context
chmod +x ../generated/04-context

# Scenario-building tools
go build -o ../generated/01-segment-manuscript ../tools/scenario-building/01-segment-manuscript/main.go
go build -o ../generated/02-inspect-segments ../tools/scenario-building/02-inspect-segments/main.go
go build -o ../generated/03-add-scenario ../tools/scenario-building/03-add-scenario/main.go

# Rust tools
echo "Building Rust tools..."
cd ../rust
cargo build --release --bin segment-manuscript
cp target/release/segment-manuscript ../generated/segment-manuscript-rust

echo "Done. Binaries in generated/"
ls -lh ../generated/
