#!/usr/bin/env bash
# SXIVA CLI wrapper script
# This allows running 'sxiva' without pip installation

# Get the actual location of this script (resolves symlinks)
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"

# Save original PWD before cd (for --all flag to work correctly)
export SXIVA_ORIGINAL_DIR="$PWD"

# Run the Python CLI from the tools directory using venv
cd "$SCRIPT_DIR/tools" && "$SCRIPT_DIR/.venv/bin/python" -m sxiva.cli "$@"
