#!/bin/bash
# Update segmenter files from 15.segman project
# This script copies the latest segmenter implementations and tracks the version

set -e

SEGMAN_DIR="../15.segman"
SEGMAN_SRC="$SEGMAN_DIR/src/segman"
VERSION_FILE="$SEGMAN_DIR/VERSION.json"

# Check if segman directory exists
if [ ! -d "$SEGMAN_DIR" ]; then
  echo "Error: $SEGMAN_DIR directory not found"
  exit 1
fi

# Read version from VERSION.json
if [ ! -f "$VERSION_FILE" ]; then
  echo "Error: $VERSION_FILE not found"
  exit 1
fi

VERSION=$(cat "$VERSION_FILE" | grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"\([^"]*\)".*/\1/')
echo "Updating segmenters to version: $VERSION"

# Copy Go segmenter
echo "Copying Go segmenter..."
mkdir -p internal/senseg
cp "$SEGMAN_SRC/go/segman.go" internal/senseg/segmenter.go
echo "  ✓ Copied to internal/senseg/segmenter.go"

# Copy JS segmenter
echo "Copying JS segmenter..."
cp "$SEGMAN_SRC/js/segman.js" web/js/segmenter.js
echo "  ✓ Copied to web/js/segmenter.js"

# Write VERSION.json for tracking
echo "{\"version\":\"$VERSION\"}" > VERSION.json
echo "  ✓ Updated VERSION.json"

echo ""
echo "✓ Segmenter update complete!"
echo "  Version: $VERSION"
echo ""
echo "Next steps:"
echo "  1. Rebuild CLI: go build -o bin/writesys ./cli/writesys"
echo "  2. Rebuild API: go build -o bin/api ./api"
echo "  3. Test with: ./bin/writesys --repo <repo> --file <file> --commit <hash> --yes"
