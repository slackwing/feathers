<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="004-create-sentence-table" author="andrew">
        <createTable tableName="sentence">
            <column name="sentence_id" type="VARCHAR(100)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="commit_hash" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="text" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="word_count" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="ordinal" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            constraintName="fk_sentence_commit"
            baseTableName="sentence"
            baseColumnNames="commit_hash"
            referencedTableName="processed_commit"
            referencedColumnNames="commit_hash"
            onDelete="CASCADE"/>

        <addUniqueConstraint
            tableName="sentence"
            columnNames="commit_hash, ordinal"
            constraintName="uq_sentence_commit_ordinal"/>

        <createIndex tableName="sentence" indexName="idx_sentence_commit">
            <column name="commit_hash"/>
        </createIndex>

        <createIndex tableName="sentence" indexName="idx_sentence_ordinal">
            <column name="commit_hash"/>
            <column name="ordinal"/>
        </createIndex>

        <rollback>
            <dropTable tableName="sentence"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
