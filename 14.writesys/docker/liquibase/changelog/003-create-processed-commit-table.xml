<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="003-create-processed-commit-table" author="andrew">
        <createTable tableName="processed_commit">
            <column name="commit_hash" type="VARCHAR(40)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="manuscript_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="parent_commit_hash" type="VARCHAR(40)">
                <constraints nullable="true"/>
            </column>
            <column name="branch_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="processed_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="sentence_count" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="additions_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="deletions_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="changes_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="sentence_id_array" type="JSONB">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            constraintName="fk_processed_commit_manuscript"
            baseTableName="processed_commit"
            baseColumnNames="manuscript_id"
            referencedTableName="manuscript"
            referencedColumnNames="manuscript_id"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            constraintName="fk_processed_commit_parent"
            baseTableName="processed_commit"
            baseColumnNames="parent_commit_hash"
            referencedTableName="processed_commit"
            referencedColumnNames="commit_hash"
            onDelete="SET NULL"/>

        <createIndex tableName="processed_commit" indexName="idx_processed_commit_manuscript">
            <column name="manuscript_id"/>
        </createIndex>

        <createIndex tableName="processed_commit" indexName="idx_processed_commit_branch">
            <column name="branch_name"/>
        </createIndex>

        <createIndex tableName="processed_commit" indexName="idx_processed_commit_processed_at">
            <column name="processed_at"/>
        </createIndex>

        <sql>
            CREATE INDEX idx_processed_commit_sentence_array ON processed_commit USING GIN(sentence_id_array);
        </sql>

        <rollback>
            <dropTable tableName="processed_commit"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
