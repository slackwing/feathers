<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="003-create-migration-table" author="andrew">
        <createTable tableName="migration">
            <column name="migration_id" type="SERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="manuscript_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="commit_hash" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="segmenter" type="VARCHAR(50)" defaultValue="segman-1.0.0">
                <constraints nullable="false"/>
            </column>
            <column name="parent_migration_id" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="branch_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="processed_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="sentence_count" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="additions_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="deletions_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="changes_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="sentence_id_array" type="JSONB">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Unique constraint: Each (manuscript_id, commit_hash, segmenter) combo is unique -->
        <addUniqueConstraint
            tableName="migration"
            columnNames="manuscript_id, commit_hash, segmenter"
            constraintName="unique_migration_commit_segmenter"/>

        <addForeignKeyConstraint
            constraintName="fk_migration_manuscript"
            baseTableName="migration"
            baseColumnNames="manuscript_id"
            referencedTableName="manuscript"
            referencedColumnNames="manuscript_id"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            constraintName="fk_migration_parent"
            baseTableName="migration"
            baseColumnNames="parent_migration_id"
            referencedTableName="migration"
            referencedColumnNames="migration_id"
            onDelete="SET NULL"/>

        <createIndex tableName="migration" indexName="idx_migration_manuscript">
            <column name="manuscript_id"/>
        </createIndex>

        <createIndex tableName="migration" indexName="idx_migration_commit">
            <column name="commit_hash"/>
        </createIndex>

        <createIndex tableName="migration" indexName="idx_migration_segmenter">
            <column name="segmenter"/>
        </createIndex>

        <createIndex tableName="migration" indexName="idx_migration_branch">
            <column name="branch_name"/>
        </createIndex>

        <createIndex tableName="migration" indexName="idx_migration_processed_at">
            <column name="processed_at"/>
        </createIndex>

        <sql>
            CREATE INDEX idx_migration_sentence_array ON migration USING GIN(sentence_id_array);
        </sql>

        <rollback>
            <dropTable tableName="migration"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
