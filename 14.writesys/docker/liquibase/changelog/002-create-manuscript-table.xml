<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="002-create-manuscript-table" author="andrew">
        <createTable tableName="manuscript">
            <column name="manuscript_id" type="SERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="repo_path" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="story_file_path" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
            tableName="manuscript"
            columnNames="repo_path, story_file_path"
            constraintName="uq_manuscript_repo_file"/>

        <rollback>
            <dropTable tableName="manuscript"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
